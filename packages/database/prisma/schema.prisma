generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String           @id @db.Uuid
  email             String?
  fullName          String?          @map("full_name")
  role              UserRole         @default(client)
  status            String           @default("active")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  uploadedDocuments Document[]       @relation("DocumentUploader")
  expensesSpent     Expense[]        @relation("ExpenseSpender")
  notifications     Notification[]
  payrollEntries    Payroll[]        @relation("PayrollUser")
  uploadedPhotos    Photo[]          @relation("PhotoUploader")
  memberships       ProjectMember[]
  projectTriggers   ProjectTrigger[]
  managedProjects   Project[]        @relation("ProjectManager")
  assignedTasks     Task[]           @relation("TaskAssignee")

  @@map("profiles")
}

model Client {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  type           String      @default("individual")
  contactPerson  String?     @map("contact_person")
  primaryEmail   String?     @map("primary_email")
  primaryPhone   String?     @map("primary_phone")
  taxId          String?     @map("tax_id")
  billingAddress String?     @map("billing_address")
  notes          String?
  portalUserId   String?     @map("portal_user_id") @db.Uuid
  createdById    String?     @map("created_by") @db.Uuid
  updatedById    String?     @map("updated_by") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?   @map("deleted_at") @db.Timestamptz(6)
  contracts      Contract[]
  payments       Payment[]
  projects       Project[]
  quotations     Quotation[]

  @@index([name])
  @@index([portalUserId])
  @@map("clients")
}

model Project {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String                 @unique
  name               String
  clientId           String                 @map("client_id") @db.Uuid
  managerId          String?                @map("manager_id") @db.Uuid
  status             ProjectStatus          @default(planning)
  address            String?
  startDate          DateTime?              @map("start_date") @db.Date
  endDate            DateTime?              @map("end_date") @db.Date
  contractValue      Decimal?               @map("contract_value") @db.Decimal(14, 2)
  budgetCost         Decimal?               @map("budget_cost") @db.Decimal(14, 2)
  actualCost         Decimal                @default(0) @map("actual_cost") @db.Decimal(14, 2)
  progressPct        Decimal                @default(0) @map("progress_pct") @db.Decimal(5, 2)
  createdById        String?                @map("created_by") @db.Uuid
  updatedById        String?                @map("updated_by") @db.Uuid
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?              @map("deleted_at") @db.Timestamptz(6)
  commissionRate     Decimal                @default(0) @map("commission_rate") @db.Decimal(6, 3)
  boqs               Boq[]
  contracts          Contract[]
  disbursements      Disbursement[]
  documents          Document[]
  expenses           Expense[]
  payments           Payment[]
  payrollAllocations Payroll[]              @relation("PayrollProject")
  photos             Photo[]
  members            ProjectMember[]
  notes              ProjectNote[]
  statusHistory      ProjectStatusHistory[]
  triggers           ProjectTrigger[]
  client             Client                 @relation(fields: [clientId], references: [id])
  manager            User?                  @relation("ProjectManager", fields: [managerId], references: [id])
  purchaseOrders     PurchaseOrder[]
  quotations         Quotation[]
  tasks              Task[]
  wageEntries        WageEntry[]

  @@index([clientId])
  @@index([managerId])
  @@index([status])
  @@map("projects")
}

model ProjectStatusHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  status      String
  changedById String?  @map("changed_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_status_history")
}

model ProjectNote {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  authorId   String?  @map("author_id") @db.Uuid
  authorName String?  @map("author_name")
  body       String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_notes")
}

model Referral {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrerName    String         @map("referrer_name")
  referrerContact String?        @map("referrer_contact")
  projectTitle    String         @map("project_title")
  details         String?
  prospectName    String?        @map("prospect_name")
  budget          Decimal?       @db.Decimal(14, 2)
  source          String         @default("website")
  status          ReferralStatus @default(new)
  adminNote       String?        @map("admin_note")
  handledById     String?        @map("handled_by") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@map("referrals")
}

model WageEntry {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String?    @map("project_id") @db.Uuid
  workerName  String     @map("worker_name")
  roleLabel   String?    @map("role_label")
  daysWorked  Decimal    @default(0) @map("days_worked") @db.Decimal(6, 2)
  amount      Decimal    @db.Decimal(14, 2)
  workDate    DateTime?  @map("work_date") @db.Date
  status      WageStatus @default(unpaid)
  note        String?
  paidAt      DateTime?  @map("paid_at") @db.Timestamptz(6)
  createdById String?    @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  project     Project?   @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status, createdAt])
  @@map("wage_entries")
}

model Disbursement {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String?            @map("project_id") @db.Uuid
  requesterName String             @map("requester_name")
  requestedById String?            @map("requested_by") @db.Uuid
  amount        Decimal            @db.Decimal(14, 2)
  reason        String?
  neededDate    DateTime?          @map("needed_date") @db.Date
  status        DisbursementStatus @default(pending)
  approvedById  String?            @map("approved_by") @db.Uuid
  approvedAt    DateTime?          @map("approved_at") @db.Timestamptz(6)
  paidAt        DateTime?          @map("paid_at") @db.Timestamptz(6)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  project       Project?           @relation(fields: [projectId], references: [id])

  @@index([status, createdAt])
  @@index([requestedById])
  @@index([projectId])
  @@map("disbursements")
}

model ProjectMember {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String            @map("project_id") @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  projectRole ProjectMemberRole @default(member) @map("project_role")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model Boq {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String?      @map("project_id") @db.Uuid
  version         Int          @default(1)
  status          BoqStatus    @default(draft)
  title           String?
  notes           String?
  totalCost       Decimal      @default(0) @map("total_cost") @db.Decimal(14, 2)
  submittedAt     DateTime?    @map("submitted_at") @db.Timestamptz(6)
  approvedAt      DateTime?    @map("approved_at") @db.Timestamptz(6)
  approvedById    String?      @map("approved_by") @db.Uuid
  createdById     String?      @map("created_by") @db.Uuid
  updatedById     String?      @map("updated_by") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz(6)
  proposerName    String?      @map("proposer_name")
  vatEnabled      Boolean      @default(true) @map("vat_enabled")
  whtEnabled      Boolean      @default(true) @map("wht_enabled")
  paymentSchedule Json?        @map("payment_schedule")
  site            String?
  clientName      String?      @map("client_name")
  docDate         DateTime?    @map("doc_date") @db.Date
  lineItems       BoqItem[]    @relation("BoqLineItems")
  sections        BoqSection[]
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotations      Quotation[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([status])
  @@map("boqs")
}

model BoqSection {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  boqId      String        @map("boq_id") @db.Uuid
  name       String
  sortOrder  Int           @default(0) @map("sort_order")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  categories BoqCategory[]
  boq        Boq           @relation(fields: [boqId], references: [id], onDelete: Cascade)

  @@index([boqId, sortOrder])
  @@map("boq_sections")
}

model BoqCategory {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId String     @map("section_id") @db.Uuid
  name      String
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  section   BoqSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items     BoqItem[]

  @@index([sectionId, sortOrder])
  @@map("boq_categories")
}

model BoqItem {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId    String?      @map("category_id") @db.Uuid
  materialId    String?      @map("material_id") @db.Uuid
  supplierId    String?      @map("supplier_id") @db.Uuid
  itemCode      String?      @map("item_code")
  description   String
  unit          String?
  quantity      Decimal      @default(0) @db.Decimal(14, 3)
  materialCost  Decimal      @default(0) @map("material_cost") @db.Decimal(14, 2)
  laborCost     Decimal      @default(0) @map("labor_cost") @db.Decimal(14, 2)
  equipmentCost Decimal      @default(0) @map("equipment_cost") @db.Decimal(14, 2)
  overhead      Decimal      @default(0) @db.Decimal(14, 2)
  sellingPrice  Decimal      @default(0) @map("selling_price") @db.Decimal(14, 2)
  notes         String?
  sortOrder     Int          @default(0) @map("sort_order")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  boqId         String?      @map("boq_id") @db.Uuid
  sectionLabel  String?      @map("section_label")
  size          String?
  boq           Boq?         @relation("BoqLineItems", fields: [boqId], references: [id], onDelete: Cascade)
  category      BoqCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  material      Material?    @relation(fields: [materialId], references: [id])
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])

  @@index([categoryId, sortOrder])
  @@index([boqId, sortOrder])
  @@index([materialId])
  @@index([supplierId])
  @@map("boq_items")
}

model Quotation {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationNo   String          @unique @map("quotation_no")
  boqId         String?         @map("boq_id") @db.Uuid
  projectId     String          @map("project_id") @db.Uuid
  clientId      String          @map("client_id") @db.Uuid
  version       Int             @default(1)
  title         String?
  marginPct     Decimal         @default(0) @map("margin_pct") @db.Decimal(6, 2)
  discountType  String          @default("amount") @map("discount_type")
  discountValue Decimal         @default(0) @map("discount_value") @db.Decimal(14, 2)
  discount      Decimal         @default(0) @db.Decimal(14, 2)
  taxPct        Decimal         @default(0) @map("tax_pct") @db.Decimal(6, 2)
  taxAmount     Decimal         @default(0) @map("tax_amount") @db.Decimal(14, 2)
  subtotal      Decimal         @default(0) @db.Decimal(14, 2)
  total         Decimal         @default(0) @db.Decimal(14, 2)
  status        QuotationStatus @default(draft)
  issueDate     DateTime?       @map("issue_date") @db.Date
  expiryDate    DateTime?       @map("expiry_date") @db.Date
  paymentTerms  String?         @map("payment_terms")
  warranty      String?
  scope         String?
  excludedItems String?         @map("excluded_items")
  notes         String?
  sentAt        DateTime?       @map("sent_at") @db.Timestamptz(6)
  viewedAt      DateTime?       @map("viewed_at") @db.Timestamptz(6)
  approvedAt    DateTime?       @map("approved_at") @db.Timestamptz(6)
  rejectedAt    DateTime?       @map("rejected_at") @db.Timestamptz(6)
  createdById   String?         @map("created_by") @db.Uuid
  updatedById   String?         @map("updated_by") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?       @map("deleted_at") @db.Timestamptz(6)
  contracts     Contract[]
  items         QuotationItem[]
  boq           Boq?            @relation(fields: [boqId], references: [id])
  client        Client          @relation(fields: [clientId], references: [id])
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([boqId])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationId String    @map("quotation_id") @db.Uuid
  description String
  unit        String?
  quantity    Decimal   @default(0) @db.Decimal(14, 3)
  unitPrice   Decimal   @default(0) @map("unit_price") @db.Decimal(14, 2)
  lineTotal   Decimal   @default(0) @map("line_total") @db.Decimal(14, 2)
  sortOrder   Int       @default(0) @map("sort_order")
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

model Contract {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractNo     String              @unique @map("contract_no")
  quotationId    String              @map("quotation_id") @db.Uuid
  projectId      String              @map("project_id") @db.Uuid
  clientId       String              @map("client_id") @db.Uuid
  title          String?
  version        Int                 @default(1)
  status         ContractStatus      @default(draft)
  value          Decimal             @default(0) @db.Decimal(14, 2)
  scope          String?
  paymentTerms   String?             @map("payment_terms")
  warranty       String?
  notes          String?
  startDate      DateTime?           @map("start_date") @db.Date
  endDate        DateTime?           @map("end_date") @db.Date
  approvedAt     DateTime?           @map("approved_at") @db.Timestamptz(6)
  approvedById   String?             @map("approved_by") @db.Uuid
  signedAt       DateTime?           @map("signed_at") @db.Timestamptz(6)
  signedById     String?             @map("signed_by") @db.Uuid
  clientSignedAt DateTime?           @map("client_signed_at") @db.Timestamptz(6)
  cancelledAt    DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  completedAt    DateTime?           @map("completed_at") @db.Timestamptz(6)
  createdById    String?             @map("created_by") @db.Uuid
  updatedById    String?             @map("updated_by") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?           @map("deleted_at") @db.Timestamptz(6)
  comments       ContractComment[]
  files          ContractFile[]
  logs           ContractLog[]
  milestones     ContractMilestone[]
  versions       ContractVersion[]
  client         Client              @relation(fields: [clientId], references: [id])
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotation      Quotation           @relation(fields: [quotationId], references: [id])

  @@index([projectId])
  @@index([clientId])
  @@index([quotationId])
  @@index([status])
  @@map("contracts")
}

model ContractVersion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId  String   @map("contract_id") @db.Uuid
  version     Int
  snapshot    Json
  note        String?
  createdById String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, version])
  @@index([contractId, version])
  @@map("contract_versions")
}

model ContractMilestone {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId    String                 @map("contract_id") @db.Uuid
  title         String
  percentage    Decimal                @default(0) @db.Decimal(6, 3)
  amount        Decimal                @default(0) @db.Decimal(14, 2)
  dueDate       DateTime?              @map("due_date") @db.Date
  paymentStatus MilestonePaymentStatus @default(unpaid) @map("payment_status")
  invoiceStatus MilestoneInvoiceStatus @default(not_invoiced) @map("invoice_status")
  sortOrder     Int                    @default(0) @map("sort_order")
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  contract      Contract               @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, sortOrder])
  @@map("contract_milestones")
}

model ContractFile {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId   String    @map("contract_id") @db.Uuid
  fileName     String    @map("file_name")
  fileUrl      String    @map("file_url")
  mimeType     String?   @map("mime_type")
  sizeBytes    BigInt?   @map("size_bytes")
  uploadedById String?   @map("uploaded_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  contract     Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_files")
}

model ContractComment {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId String    @map("contract_id") @db.Uuid
  authorId   String?   @map("author_id") @db.Uuid
  body       String
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  contract   Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
  @@map("contract_comments")
}

model ContractLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId String   @map("contract_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  detail     String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
  @@map("contract_logs")
}

model Expense {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String?        @map("project_id") @db.Uuid
  spentById   String?        @map("spent_by") @db.Uuid
  category    String
  description String?
  amount      Decimal        @default(0) @db.Decimal(14, 2)
  status      ApprovalStatus @default(draft)
  isBillable  Boolean        @default(true) @map("is_billable")
  receiptUrl  String?        @map("receipt_url")
  incurredAt  DateTime       @default(now()) @map("incurred_at") @db.Timestamptz(6)
  approvedAt  DateTime?      @map("approved_at") @db.Timestamptz(6)
  createdById String?        @map("created_by") @db.Uuid
  updatedById String?        @map("updated_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz(6)
  items       ExpenseItem[]
  project     Project?       @relation(fields: [projectId], references: [id])
  spender     User?          @relation("ExpenseSpender", fields: [spentById], references: [id])

  @@index([projectId])
  @@index([spentById])
  @@index([status])
  @@map("expenses")
}

model ExpenseItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expenseId   String  @map("expense_id") @db.Uuid
  description String
  quantity    Decimal @default(1) @db.Decimal(14, 3)
  unitPrice   Decimal @default(0) @map("unit_price") @db.Decimal(14, 2)
  lineTotal   Decimal @default(0) @map("line_total") @db.Decimal(14, 2)
  sortOrder   Int     @default(0) @map("sort_order")
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@map("expense_items")
}

model Payment {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  direction       PaymentDirection
  partyType       String           @map("party_type")
  clientId        String?          @map("client_id") @db.Uuid
  supplierId      String?          @map("supplier_id") @db.Uuid
  purchaseOrderId String?          @map("purchase_order_id") @db.Uuid
  projectId       String?          @map("project_id") @db.Uuid
  amount          Decimal          @db.Decimal(14, 2)
  method          PaymentMethod?
  reference       String?
  note            String?
  paidAt          DateTime         @default(now()) @map("paid_at") @db.Timestamptz(6)
  createdById     String?          @map("created_by") @db.Uuid
  updatedById     String?          @map("updated_by") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  client          Client?          @relation(fields: [clientId], references: [id])
  project         Project?         @relation(fields: [projectId], references: [id])
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])

  @@index([clientId])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([projectId])
  @@index([paidAt])
  @@map("payments")
}

model Payroll {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  projectId   String?       @map("project_id") @db.Uuid
  periodStart DateTime      @map("period_start") @db.Date
  periodEnd   DateTime      @map("period_end") @db.Date
  daysWorked  Decimal       @default(0) @map("days_worked") @db.Decimal(6, 2)
  gross       Decimal       @default(0) @db.Decimal(14, 2)
  allowances  Decimal       @default(0) @db.Decimal(14, 2)
  deductions  Decimal       @default(0) @db.Decimal(14, 2)
  net         Decimal       @default(0) @db.Decimal(14, 2)
  status      PayrollStatus @default(draft)
  paidAt      DateTime?     @map("paid_at") @db.Timestamptz(6)
  createdById String?       @map("created_by") @db.Uuid
  updatedById String?       @map("updated_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  project     Project?      @relation("PayrollProject", fields: [projectId], references: [id])
  user        User          @relation("PayrollUser", fields: [userId], references: [id])

  @@unique([userId, periodStart, periodEnd])
  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@map("payroll")
}

model Supplier {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  contactName    String?         @map("contact_name")
  email          String?
  phone          String?
  paymentTerms   String?         @map("payment_terms")
  rating         Int?
  createdById    String?         @map("created_by") @db.Uuid
  updatedById    String?         @map("updated_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(6)
  boqItems       BoqItem[]
  materials      Material[]
  payments       Payment[]
  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@map("suppliers")
}

model Material {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  sku          String?             @unique
  unit         String
  category     String?
  unitCost     Decimal             @default(0) @map("unit_cost") @db.Decimal(14, 2)
  onHandQty    Decimal             @default(0) @map("on_hand_qty") @db.Decimal(14, 3)
  reorderLevel Decimal             @default(0) @map("reorder_level") @db.Decimal(14, 3)
  supplierId   String?             @map("supplier_id") @db.Uuid
  createdById  String?             @map("created_by") @db.Uuid
  updatedById  String?             @map("updated_by") @db.Uuid
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?           @map("deleted_at") @db.Timestamptz(6)
  boqItems     BoqItem[]
  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  poItems      PurchaseOrderItem[]

  @@index([name])
  @@index([supplierId])
  @@map("materials")
}

model PurchaseOrder {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poNo         String              @unique @map("po_no")
  supplierId   String              @map("supplier_id") @db.Uuid
  projectId    String?             @map("project_id") @db.Uuid
  status       PoStatus            @default(draft)
  total        Decimal             @default(0) @db.Decimal(14, 2)
  expectedDate DateTime?           @map("expected_date") @db.Date
  orderedAt    DateTime?           @map("ordered_at") @db.Timestamptz(6)
  createdById  String?             @map("created_by") @db.Uuid
  updatedById  String?             @map("updated_by") @db.Uuid
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?           @map("deleted_at") @db.Timestamptz(6)
  payments     Payment[]
  items        PurchaseOrderItem[]
  project      Project?            @relation(fields: [projectId], references: [id])
  supplier     Supplier            @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([projectId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String        @map("purchase_order_id") @db.Uuid
  materialId      String?       @map("material_id") @db.Uuid
  description     String
  unit            String?
  quantity        Decimal       @default(0) @db.Decimal(14, 3)
  unitPrice       Decimal       @default(0) @map("unit_price") @db.Decimal(14, 2)
  lineTotal       Decimal       @default(0) @map("line_total") @db.Decimal(14, 2)
  receivedQty     Decimal       @default(0) @map("received_qty") @db.Decimal(14, 3)
  sortOrder       Int           @default(0) @map("sort_order")
  material        Material?     @relation(fields: [materialId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([materialId])
  @@map("purchase_order_items")
}

model Task {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String     @map("project_id") @db.Uuid
  parentTaskId String?    @map("parent_task_id") @db.Uuid
  assigneeId   String?    @map("assignee_id") @db.Uuid
  name         String
  description  String?
  status       TaskStatus @default(todo)
  progressPct  Decimal    @default(0) @map("progress_pct") @db.Decimal(5, 2)
  plannedStart DateTime?  @map("planned_start") @db.Date
  plannedEnd   DateTime?  @map("planned_end") @db.Date
  sortOrder    Int        @default(0) @map("sort_order")
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)
  photos       Photo[]
  assignee     User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  parent       Task?      @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subtasks     Task[]     @relation("TaskHierarchy")
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([assigneeId])
  @@index([parentTaskId])
  @@index([status])
  @@map("tasks")
}

model Document {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String?            @map("project_id") @db.Uuid
  uploadedById String?            @map("uploaded_by") @db.Uuid
  category     String
  title        String
  fileUrl      String             @map("file_url")
  fileName     String?            @map("file_name")
  mimeType     String?            @map("mime_type")
  sizeBytes    BigInt?            @map("size_bytes")
  version      Int                @default(1)
  visibility   DocumentVisibility @default(internal)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz(6)
  project      Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader     User?              @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([visibility])
  @@index([uploadedById])
  @@map("documents")
}

model Photo {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String      @map("project_id") @db.Uuid
  taskId       String?     @map("task_id") @db.Uuid
  uploadedById String?     @map("uploaded_by") @db.Uuid
  fileUrl      String      @map("file_url")
  caption      String?
  phase        PhotoPhase?
  takenAt      DateTime?   @map("taken_at") @db.Timestamptz(6)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task         Task?       @relation(fields: [taskId], references: [id])
  uploader     User?       @relation("PhotoUploader", fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([taskId])
  @@index([uploadedById])
  @@map("photos")
}

model Notification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String
  title      String
  body       String?
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProjectTrigger {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  message     String
  triggerAt   DateTime  @map("trigger_at") @db.Timestamptz(6)
  sentAt      DateTime? @map("sent_at") @db.Timestamptz(6)
  createdById String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy   User?     @relation(fields: [createdById], references: [id], onUpdate: NoAction)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([triggerAt, sentAt], map: "idx_project_triggers_due")
  @@index([projectId, triggerAt], map: "idx_project_triggers_project")
  @@map("project_triggers")
}

