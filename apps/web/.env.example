# ---- Supabase (Authentication) ----
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Public anon key (safe to expose to the browser; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL — used to build password-reset redirect links.
# Local: http://localhost:3000 · Prod: https://app.artiverges.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Prisma (Supabase Postgres) ----
# Read by Prisma (which bypasses RLS — RBAC is enforced in the app layer).
# Supabase → Project Settings → Database → Connection string.
# Pooled connection (PgBouncer, port 6543) for the running app:
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) for migrations / introspection:
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---- LINE Messaging API (project trigger reminders) ----
# LINE Developers Console → your Messaging API channel → Channel access token.
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
# Group ID of the shared LINE group the bot has been added to.
LINE_GROUP_ID=your-line-group-id
# LINE Developers Console → Messaging API channel → Channel secret. Verifies
# the /api/line/webhook signature (x-line-signature) for the "Done" button.
LINE_CHANNEL_SECRET=your-line-channel-secret

# ---- Cron (Vercel Cron → /api/cron/triggers) ----
# Any random secret; Vercel sends it automatically as a bearer token for its
# own scheduled invocations of this project's cron jobs.
CRON_SECRET=your-cron-secret
